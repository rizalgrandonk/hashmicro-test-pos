<%
  title = 'Point of Sale'
  fullHeight = true
%>

<div class="flex overflow-hidden" style="height: calc(100vh - 4rem)">

  <!-- LEFT PANEL: Product Grid -->
  <div class="flex-1 flex flex-col overflow-hidden p-5 gap-4">

    <!-- Header -->
    <div class="flex items-center justify-between shrink-0">
      <div>
        <h1 class="text-2xl font-bold">Point of Sale</h1>
        <p class="text-base-content/60 text-sm mt-0.5"><%= products.length %> products available</p>
      </div>
      <a href="/pos/history" class="btn btn-outline btn-sm gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        Order History
      </a>
    </div>

    <!-- Search -->
    <form method="GET" action="/pos" class="shrink-0">
      <div class="input input-bordered flex items-center gap-2 w-full">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
        </svg>
        <input type="text" name="search" placeholder="Search by name, SKU, or category…"
          value="<%= search %>" class="grow" />
        <% if (search) { %>
          <a href="/pos" class="text-base-content/40 hover:text-base-content">✕</a>
        <% } %>
      </div>
    </form>

    <% if (error === 'stock') { %>
      <div class="alert alert-error alert-soft shrink-0 py-2">
        <span>Requested quantity exceeds available stock.</span>
      </div>
    <% } %>

    <!-- Product cards -->
    <div class="flex-1 overflow-y-auto">
      <% if (products.length === 0) { %>
        <div class="flex items-center justify-center h-48 text-base-content/40">
          No products found.
        </div>
      <% } else { %>
        <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 pb-3">
          <% for (const product of products) { %>
            <div class="card bg-base-100 shadow-sm border border-base-200 <%= product.stock === 0 ? 'opacity-50' : '' %>">
              <div class="card-body p-4 gap-2">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-semibold text-sm leading-tight line-clamp-2"><%= product.name %></h3>
                  <% if (product.stockStatus === 'out') { %>
                    <span class="badge badge-soft badge-error badge-xs shrink-0">Out</span>
                  <% } else if (product.stockStatus === 'low') { %>
                    <span class="badge badge-soft badge-warning badge-xs shrink-0">Low</span>
                  <% } %>
                </div>
                <p class="font-mono text-xs text-base-content/50"><%= product.sku %></p>
                <span class="badge badge-outline badge-sm w-fit"><%= product.category %></span>
                <p class="font-bold text-primary"><%= formatCurrency(product.price) %></p>
                <p class="text-xs text-base-content/50">Stock: <%= product.stock %></p>

                <% if (product.stock > 0) { %>
                  <form action="/pos/cart/add" method="POST" class="flex gap-1 mt-1">
                    <input type="hidden" name="productId" value="<%= product.id %>" />
                    <input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>"
                      class="input input-bordered input-sm w-16" />
                    <button type="submit" class="btn btn-primary btn-sm flex-1">Add</button>
                  </form>
                <% } else { %>
                  <button class="btn btn-sm btn-disabled w-full mt-1" disabled>Out of Stock</button>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

  </div>

  <!-- RIGHT PANEL: Cart Sidebar -->
  <div class="w-80 shrink-0 flex flex-col border-l border-base-200 bg-base-100">

    <!-- Cart header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-base-200">
      <h2 class="font-bold text-lg">Cart</h2>
      <% if (cartCount > 0) { %>
        <span class="badge badge-primary"><%= cartCount %> items</span>
      <% } %>
    </div>

    <!-- Cart items -->
    <div class="flex-1 overflow-y-auto px-4 py-3 flex flex-col gap-2">
      <% if (cart.length === 0) { %>
        <div class="flex flex-col items-center justify-center h-full text-base-content/40 gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <p class="text-sm">Cart is empty</p>
        </div>
      <% } else { %>
        <% for (const item of cart) { %>
          <div class="card bg-base-200 p-3 gap-1">
            <p class="font-medium text-sm line-clamp-1"><%= item.name %></p>
            <p class="text-xs text-base-content/50"><%= formatCurrency(item.unitPrice) %> each</p>
            <div class="flex items-center justify-between mt-1 gap-2">
              <form action="/pos/cart/update" method="POST" class="flex items-center gap-1">
                <input type="hidden" name="productId" value="<%= item.productId %>" />
                <button type="submit" name="quantity" value="<%= item.quantity - 1 %>"
                  class="btn btn-xs btn-ghost px-2">−</button>
                <span class="w-8 text-center text-sm font-mono"><%= item.quantity %></span>
                <button type="submit" name="quantity" value="<%= item.quantity + 1 %>"
                  class="btn btn-xs btn-ghost px-2 <%= item.quantity >= item.stock ? 'btn-disabled' : '' %>">+</button>
              </form>
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold"><%= formatCurrency(item.unitPrice * item.quantity) %></span>
                <form action="/pos/cart/update" method="POST">
                  <input type="hidden" name="productId" value="<%= item.productId %>" />
                  <button type="submit" name="quantity" value="0" class="btn btn-ghost btn-xs text-error px-1">✕</button>
                </form>
              </div>
            </div>
          </div>
        <% } %>
      <% } %>
    </div>

    <!-- Cart footer -->
    <div class="px-5 py-4 border-t border-base-200 flex flex-col gap-3">
      <% if (cart.length > 0) { %>
        <div class="flex justify-between text-sm">
          <span class="text-base-content/60">Subtotal (before discounts)</span>
          <span class="font-semibold"><%= formatCurrency(cartSubtotal) %></span>
        </div>
        <p class="text-xs text-base-content/40">Discounts & tax applied at checkout.</p>
        <a href="/pos/checkout" class="btn btn-primary w-full">Proceed to Checkout</a>
        <form action="/pos/cart/clear" method="POST">
          <button type="submit" class="btn btn-ghost btn-sm w-full text-error">Clear Cart</button>
        </form>
      <% } else { %>
        <a href="/pos/checkout" class="btn btn-primary w-full btn-disabled">Proceed to Checkout</a>
      <% } %>
    </div>

  </div>
</div>
