<% title = 'Edit Product' %>

<div class="max-w-2xl mx-auto">

  <div class="mb-6">
    <a href="/products" class="btn btn-ghost btn-sm gap-1 pl-0">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    </a>
    <h1 class="text-2xl font-bold mt-2">Edit Product</h1>
  </div>

  <% if (error) { %>
    <div class="alert alert-error mb-4">
      <span><%= error %></span>
    </div>
  <% } %>

  <div class="card bg-base-100 shadow-sm">
    <div class="card-body gap-4">
      <form action="/products/<%= product.id %>" method="POST" class="flex flex-col gap-4">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <label class="floating-label">
            <span>Product Name</span>
            <input type="text" name="name" class="input input-bordered" placeholder="Product Name" required value="<%= product.name %>" />
          </label>
          <label class="floating-label">
            <span>SKU</span>
            <input type="text" name="sku" class="input input-bordered" placeholder="SKU" required value="<%= product.sku %>" />
          </label>
        </div>

        <label class="floating-label">
          <span>Category</span>
          <input type="text" name="category" class="input input-bordered w-full" placeholder="Category" required value="<%= product.category %>" />
        </label>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <label class="floating-label">
            <span>Price (Rp)</span>
            <input type="number" name="price" class="input input-bordered" placeholder="Price (Rp)" step="1" min="0" required value="<%= product.price %>" />
          </label>
          <label class="floating-label">
            <span>Stock</span>
            <input type="number" name="stock" class="input input-bordered" placeholder="Stock" min="0" required value="<%= product.stock %>" />
          </label>
        </div>

        <label class="floating-label">
          <span>Description</span>
          <textarea name="description" class="textarea textarea-bordered w-full" rows="3" placeholder="Description"><%= product.description %></textarea>
        </label>

        <div class="flex gap-3 justify-end mt-2">
          <a href="/products" class="btn btn-ghost">Cancel</a>
          <button type="submit" class="btn btn-primary">Update Product</button>
        </div>

      </form>
    </div>
  </div>

</div>
